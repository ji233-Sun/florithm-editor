    "description": "召唤恐龙协助僵尸",
    "icon": "paw-print",
    "color": "#91B900",
    "darkColor": "#A2B659",
    "defaultAlias": "DinoTimeEvent",
    "category": "action"
  },
  "initialData": {
    "DinoRow": 2,
    "DinoType": "raptor",
