    { "key": "DinoRow", "type": "number", "label": "出现行", "description": "恐龙出现的行号", "numberType": "int", "min": 0, "max": 5, "step": 1, "default": 2 },
    { "key": "DinoWaveDuration", "type": "number", "label": "持续波数", "description": "恐龙存在的波数", "numberType": "int", "min": 1, "max": 20, "step": 1, "default": 2 }
