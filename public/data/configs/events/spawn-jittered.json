{
  "$schema": "florithm-event-config/v1",
  "objclass": "SpawnZombiesJitteredWaveActionProps",
  "metadata": {
    "title": "自然出怪",
    "description": "标准自然僵尸生成事件",
    "icon": "users",
    "color": "#2196F3",
    "darkColor": "#90CAF9",
    "defaultAlias": "Jittered",
    "category": "spawner",
    "unique": true
  },
  "initialData": {
    "Zombies": [],
    "NotificationEvents": null,
    "AdditionalPlantfood": null,
    "SpawnPlantName": null
  },
  "fields": [
    {
      "key": "NotificationEvents",
      "type": "jam-select",
      "label": "魔音音乐切换",
      "description": "此事件触发时切换背景音乐，仅对摇滚年代地图有效",
      "default": null
    },
    {
      "key": "Zombies",
      "type": "zombie-spawn-list",
      "label": "僵尸列表",
      "description": "配置本波出怪的僵尸、行号和等级"
    },
    {
      "key": "_dropConfig",
      "type": "drop-config",
      "label": "掉落物配置",
      "description": "配置本波僵尸携带的掉落物（能量豆或植物卡片）"
    }
  ]
}
