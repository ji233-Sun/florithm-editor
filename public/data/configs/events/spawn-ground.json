{
  "$schema": "florithm-event-config/v1",
  "objclass": "SpawnZombiesFromGroundSpawnerProps",
  "metadata": {
    "title": "地下出怪",
    "description": "从设定的区间范围直接从地下生成僵尸，参数配置和自然出怪基本一致",
    "icon": "users",
    "color": "#936457",
    "darkColor": "#C2A197",
    "defaultAlias": "GroundSpawner",
    "category": "spawner"
  },
  "initialData": {
    "ColumnStart": 6,
    "ColumnEnd": 9,
    "AdditionalPlantfood": null,
    "SpawnPlantName": null,
    "Zombies": []
  },
  "fields": [
    {
      "key": "_columnRange",
      "type": "range",
      "label": "出怪范围（列数）",
      "startKey": "ColumnStart",
      "endKey": "ColumnEnd",
      "startLabel": "起始列",
      "endLabel": "结束列",
      "min": 0,
      "max": 9,
      "description": "场地左边界为 0 列，右边界为 9 列，起始列要小于结束列"
    },
    {
      "key": "Zombies",
      "type": "zombie-spawn-list",
      "label": "僵尸列表",
      "description": "配置本波从地下出现的僵尸"
    },
    {
      "key": "_dropConfig",
      "type": "drop-config",
      "label": "掉落物配置",
      "description": "配置本波僵尸携带的掉落物（能量豆或植物卡片）"
    }
  ]
}
