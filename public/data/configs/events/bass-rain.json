{
  "$schema": "florithm-event-config/v1",
  "objclass": "BassRainZombieSpawnerProps",
  "metadata": {
    "title": "低音雨",
    "description": "低音或喷气僵尸从天空降落",
    "icon": "speaker",
    "color": "#9C27B0",
    "darkColor": "#B39DDB",
    "defaultAlias": "BassRainEvent",
    "category": "spawner"
  },
  "initialData": {
    "ColumnStart": 5,
    "ColumnEnd": 9,
    "GroupSize": 1,
    "SpiderCount": 1,
    "SpiderZombieName": "",
    "TimeBeforeFullSpawn": 1.0,
    "TimeBetweenGroups": 1.5,
    "ZombieFallTime": 4.5,
    "WaveStartMessage": ""
  },
  "fields": [
    { "key": "_columnRange", "type": "range", "label": "出怪范围（列数）", "startKey": "ColumnStart", "endKey": "ColumnEnd", "startLabel": "起始列", "endLabel": "结束列", "min": 0, "max": 9, "description": "场地左边界为 0 列，右边界为 9 列" },
    { "key": "GroupSize", "type": "number", "label": "组大小", "numberType": "int", "min": 1, "max": 20, "default": 1 },
    { "key": "SpiderCount", "type": "number", "label": "数量", "numberType": "int", "min": 1, "max": 50, "default": 1 },
    { "key": "SpiderZombieName", "type": "string", "label": "僵尸名称", "default": "" },
    { "key": "TimeBeforeFullSpawn", "type": "number", "label": "完全生成前延迟", "numberType": "float", "min": 0, "max": 30, "step": 0.5, "default": 1.0 },
    { "key": "TimeBetweenGroups", "type": "number", "label": "组间隔", "numberType": "float", "min": 0, "max": 10, "step": 0.1, "default": 1.5 },
    { "key": "ZombieFallTime", "type": "number", "label": "降落时间", "numberType": "float", "min": 0, "max": 20, "step": 0.5, "default": 4.5 },
    { "key": "WaveStartMessage", "type": "string", "label": "开始消息", "default": "" }
  ]
