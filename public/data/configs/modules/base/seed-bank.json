{
  "$schema": "florithm-module-config/v1",
  "objclass": "SeedBankProperties",
  "metadata": {
    "title": "种子库",
    "description": "预选卡槽和选卡方式配置",
    "icon": "sprout",
    "category": "base",
    "isCore": true,
    "allowMultiple": true,
    "defaultAlias": "SeedBank",
    "defaultSource": "CurrentLevel"
  },
  "initialData": {
    "PresetPlantList": [],
    "PlantWhiteList": [],
    "PlantBlackList": [],
    "SelectionMethod": "chooser",
    "GlobalLevel": null,
    "OverrideSeedSlotsCount": 8,
    "ZombieMode": null,
    "SeedPacketType": null
  },
  "fields": [
    { "key": "SelectionMethod", "type": "select", "label": "选卡模式", "description": "自选卡(chooser)或预选卡(preset)", "options": ["chooser", "preset"], "default": "chooser" },
    { "key": "OverrideSeedSlotsCount", "type": "number", "label": "卡槽数量", "description": "覆盖默认卡槽数量", "numberType": "int", "min": 1, "max": 20, "step": 1, "default": 8 },
    { "key": "GlobalLevel", "type": "number", "label": "全局等级", "description": "所有植物的全局等级覆盖", "numberType": "int", "min": 1, "max": 20, "step": 1, "default": null },
    { "key": "PresetPlantList", "type": "array", "label": "预选植物列表", "description": "预选模式下的植物列表", "itemType": "plant-ref" },
    { "key": "PlantWhiteList", "type": "array", "label": "植物白名单", "description": "只允许选择这些植物", "itemType": "plant-ref" },
    { "key": "PlantBlackList", "type": "array", "label": "植物黑名单", "description": "禁止选择这些植物", "itemType": "plant-ref" },
    { "key": "ZombieMode", "type": "boolean", "label": "僵尸模式", "description": "启用僵尸选卡模式（我是僵尸）", "default": null },
    { "key": "SeedPacketType", "type": "string", "label": "种子包类型", "description": "种子包外观类型", "default": null }
  ]
}
