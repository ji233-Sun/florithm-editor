      "itemFields": [
        { "key": "GridX", "type": "number", "label": "列", "numberType": "int", "min": 0, "max": 9, "default": 0 },
        { "key": "GridY", "type": "number", "label": "行", "numberType": "int", "min": 0, "max": 5, "default": 0 },
        { "key": "Img", "type": "string", "label": "图片", "description": "隧道段的图片资源名", "default": "" }
